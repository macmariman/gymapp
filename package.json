{
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit --project tsconfig.typecheck.json",
    "check": "npm run lint && npm run type-check && npm run build",
    "format": "prettier --write \"**/*.{ts,tsx,mdx}\" --cache",
    "postinstall": "prisma generate",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:ci": "jest --ci --coverage --watchAll=false --passWithNoTests",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
