datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Routine {
  id        String           @id @default(cuid())
  name      String
  summary   String
  sortOrder Int
  sections  RoutineSection[]
  sessions  WorkoutSession[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model RoutineSection {
  id        String          @id @default(cuid())
  routineId String
  name      String
  sortOrder Int
  routine   Routine         @relation(fields: [routineId], references: [id], onDelete: Cascade)
  groups    ExerciseGroup[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([routineId, sortOrder])
}

model ExerciseGroup {
  id        String          @id @default(cuid())
  sectionId String
  name      String
  series    Int
  sortOrder Int
  section   RoutineSection  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  exercises Exercise[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([sectionId, sortOrder])
}

model ExerciseMovement {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  logType   ExerciseLogType
  exercises Exercise[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model Exercise {
  id           String             @id @default(cuid())
  groupId      String
  movementId   String
  name         String
  targetType   ExerciseMetricType
  targetValue  Int
  note         String?
  logType      ExerciseLogType    @default(none)
  sortOrder    Int
  group        ExerciseGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  movement     ExerciseMovement   @relation(fields: [movementId], references: [id], onDelete: Restrict)
  setLogs      ExerciseSetLog[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([groupId, sortOrder])
  @@index([movementId, sortOrder])
}

model WorkoutSession {
  id          String           @id @default(cuid())
  routineId   String
  performedAt DateTime         @default(now())
  note        String?
  routine     Routine          @relation(fields: [routineId], references: [id], onDelete: Cascade)
  setLogs     ExerciseSetLog[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([routineId, performedAt])
  @@index([performedAt])
}

model ExerciseSetLog {
  id         String         @id @default(cuid())
  sessionId  String
  exerciseId String
  setNumber  Int
  weightKg   Decimal?       @db.Decimal(5, 2)
  repsCount  Int?
  durationSeconds Int?
  session    WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise   Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())

  @@unique([sessionId, exerciseId, setNumber])
  @@index([exerciseId, createdAt])
}

enum ExerciseMetricType {
  reps
  weight
  time
}

enum ExerciseLogType {
  none
  reps
  weight
  time
}
